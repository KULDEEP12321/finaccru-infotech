# ── Sanity CMS ─────────────────────────────────────────────────────────────
# The LIVE Finaccru project id is already baked into sanity/env.ts as the
# default (id "2jhreob8", dataset "production"), so the CMS works out of the box
# with NO .env. These are PUBLIC values (they appear in every Sanity CDN URL),
# which is why hard-coding the default is safe.
#
# Create a `.env` from this file ONLY to point at a different project/dataset
# (e.g. a "staging" dataset) without editing source. The VITE_ prefix exposes
# them to the browser/Studio build, which is fine for these public values.
#
# VITE_SANITY_PROJECT_ID=2jhreob8
# VITE_SANITY_DATASET=production
# VITE_SANITY_API_VERSION=2024-12-01

# Only needed if you make the dataset PRIVATE (then also add `token` in
# sanity/lib/client.ts). Keep this out of version control — it is a secret.
# SANITY_READ_TOKEN=
