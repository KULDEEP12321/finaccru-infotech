# Cloudflare Workers Assets `_headers`.
# NOTE: these rules apply to STATIC-ASSET responses only (files under dist/client)
# — NOT to SSR/HTML responses generated by the Worker. So the security headers +
# CSP below harden static assets. To also put security headers (CSP,
# X-Frame-Options, HSTS) on HTML pages, add a Cloudflare Response Header Transform
# Rule at the zone level (needs a custom domain) or wrap the Worker entry.
# /studio is kept out of indexes by robots.txt Disallow + the noindex <meta> on
# the studio route (both effective on SSR); the X-Robots-Tag here is a redundant
# extra layer for any static asset under /studio.

/*
  # ── Security headers (Cloudflare-native; mirrors the reference architecture) ──
  X-Frame-Options: DENY
  X-Content-Type-Options: nosniff
  Referrer-Policy: strict-origin-when-cross-origin
  Permissions-Policy: camera=(), microphone=(), geolocation=()

  # Force HTTPS for 1 year (preload-eligible).
  Strict-Transport-Security: max-age=31536000; includeSubDomains; preload

  # Origin isolation.
  Cross-Origin-Opener-Policy: same-origin
  Cross-Origin-Resource-Policy: same-origin

  # ── Content-Security-Policy (Report-Only) ──────────────────────────────────
  # Shipped in REPORT-ONLY so it logs violations without blocking anything — the
  # embedded Sanity Studio (/studio) needs eval + blob workers + the Sanity APIs,
  # and the homepage streams an HLS showreel from Mux. Once you've loaded /studio,
  # the blog, and the homepage video with no CSP violations in the console,
  # promote this to the enforcing `Content-Security-Policy` header.
  #
  # Origins in use: Google Fonts (css + font files), Sanity (cdn + api + realtime
  # websocket), Mux (HLS .m3u8 + segments), svgl.app (marquee logos).
  Content-Security-Policy-Report-Only: default-src 'self'; script-src 'self' 'unsafe-inline' 'unsafe-eval'; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com data:; img-src 'self' data: blob: https:; media-src 'self' blob: https://stream.mux.com; connect-src 'self' https://cdn.sanity.io https://*.api.sanity.io https://*.apicdn.sanity.io wss://*.api.sanity.io https://stream.mux.com; worker-src 'self' blob:; frame-src 'self' https://*.sanity.io; object-src 'none'; base-uri 'self'; form-action 'self'; frame-ancestors 'none';

# ── Embedded Sanity Studio — keep the internal CMS admin out of every index. ──
# Replaces the equivalent rules that lived in vercel.json before the move to
# Cloudflare. Both the bare path and everything beneath it are covered.
/studio
  X-Robots-Tag: noindex, nofollow, noarchive, nosnippet
  Cache-Control: no-store
  Referrer-Policy: no-referrer

/studio/*
  X-Robots-Tag: noindex, nofollow, noarchive, nosnippet
  Cache-Control: no-store
  Referrer-Policy: no-referrer

# ── Static asset caching ─────────────────────────────────────────────────────
# Fingerprinted build assets — cache hard for a year.
/assets/*
  Cache-Control: public, max-age=31536000, immutable

# Images — cache for a month.
/*.jpg
  Cache-Control: public, max-age=2592000
/*.jpeg
  Cache-Control: public, max-age=2592000
/*.png
  Cache-Control: public, max-age=2592000
/*.webp
  Cache-Control: public, max-age=2592000
/*.avif
  Cache-Control: public, max-age=2592000
/*.svg
  Cache-Control: public, max-age=2592000

# Video — cache for a month (the showcase pad + automation hero clips).
/*.mp4
  Cache-Control: public, max-age=2592000
/*.webm
  Cache-Control: public, max-age=2592000

# Fonts — cache hard for a year.
/*.woff
  Cache-Control: public, max-age=31536000, immutable
/*.woff2
  Cache-Control: public, max-age=31536000, immutable
/*.ttf
  Cache-Control: public, max-age=31536000, immutable
/*.eot
  Cache-Control: public, max-age=31536000, immutable
